# CarLooking — environment variables
# Copy to .env for local overrides (never commit .env)
# Set these as App Settings in Azure portal for cloud deployment

# ── Required for cloud deployment ───────────────────────────────────────────
# Password to access the web UI (leave blank to disable auth locally)
CARLOOKING_PASSWORD=change-me

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-random-value-here

# ── Azure Blob Storage (persistent listings across restarts) ─────────────────
# Get this from: Azure portal -> Storage Account -> Access keys -> Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=carlooking

# ── Auto-scrape interval ─────────────────────────────────────────────────────
# How often to automatically run a full scrape (hours). 0 = disabled (manual only).
SCRAPE_INTERVAL_HOURS=12

# ── Optional overrides ───────────────────────────────────────────────────────
# PORT is set automatically by Azure App Service — don't override it there
# PORT=8000
